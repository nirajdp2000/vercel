# ─── Upstox API Credentials (OAuth-based) ────────────────────────────────────
UPSTOX_CLIENT_ID=your_client_id_here
UPSTOX_CLIENT_SECRET=your_client_secret_here

# Local dev redirect URI — change to your deployed URL for production
# e.g. https://your-app.vercel.app/api/upstox/callback
# IMPORTANT: This value must match EXACTLY what is registered in the Upstox
# developer app dashboard (https://account.upstox.com/developer/apps).
# On Vercel, set this env var in the Vercel dashboard (not in vercel.json).
UPSTOX_REDIRECT_URI=http://localhost:3000/api/upstox/callback

# Pre-set access token (optional — used on Vercel where SQLite is unavailable)
# Get this from the Upstox developer portal or after completing OAuth locally
UPSTOX_ACCESS_TOKEN=

# ─── Gemini AI Credentials ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
API_KEY=

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Set to 'production' on Vercel / Railway / Render (auto-set by most platforms)
NODE_ENV=development

# Port for local Express server (default: 3000)
PORT=3000
