{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "../server.cjs"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/upstox/(.*)", "destination": "/api/index" },
    { "source": "/sb-terminal", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
